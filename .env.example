# The repository does not auto-load this file.
# Load it manually if you use it:
#   set -a
#   source .env
#   set +a

CSAT_APP_ENV=dev
CSAT_LOG_LEVEL=INFO
CSAT_DEFAULT_SPEC_ID=csat_math_2028

# Optional runtime path overrides. Relative paths resolve from the repo root.
# CSAT_ARTIFACT_ROOT=artifacts
# CSAT_DATABASE_PATH=var/app.db
# CSAT_EXAM_SPECS_DIR=exam_specs
# CSAT_DATA_ROOT=data
# CSAT_DISTILLED_ROOT=data/distilled
# CSAT_SOURCE_FIXTURE_ROOT=data/source_fixtures

# Optional XeLaTeX override for PDF compilation.
# CSAT_XELATEX_PATH=

# Optional OpenAI provider settings.
# OPENAI_API_KEY=
CSAT_OPENAI_MODEL=gpt-4.1-mini
# CSAT_OPENAI_TIMEOUT_SECONDS=60
# CSAT_OPENAI_MAX_RETRIES=1
# CSAT_OPENAI_TEMPERATURE=0
# CSAT_OPENAI_MAX_OUTPUT_TOKENS=4000
# OPENAI_BASE_URL=
# OPENAI_ORGANIZATION=
# OPENAI_PROJECT=

# Optional cost metadata used by benchmark reporting.
# CSAT_OPENAI_INPUT_COST_PER_1M_TOKENS=0
# CSAT_OPENAI_OUTPUT_COST_PER_1M_TOKENS=0
